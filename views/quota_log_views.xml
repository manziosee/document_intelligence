<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Tree view ──────────────────────────────────────────────────────── -->
    <record id="view_doc_intel_quota_log_tree" model="ir.ui.view">
        <field name="name">document.intelligence.quota.log.tree</field>
        <field name="model">document.intelligence.quota.log</field>
        <field name="arch" type="xml">
            <tree string="API Quota Log"
                  decoration-danger="not success"
                  decoration-success="success">
                <field name="call_date"/>
                <field name="provider"/>
                <field name="model_used"/>
                <field name="document_id" optional="show"/>
                <field name="user_id" optional="show"/>
                <field name="text_chars"/>
                <field name="estimated_tokens"/>
                <field name="response_ms" string="Time (ms)"/>
                <field name="success" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <!-- ── Graph view — extractions per day by provider ──────────────────── -->
    <record id="view_doc_intel_quota_log_graph" model="ir.ui.view">
        <field name="name">document.intelligence.quota.log.graph</field>
        <field name="model">document.intelligence.quota.log</field>
        <field name="arch" type="xml">
            <graph string="Extraction Activity" type="bar" stacked="True">
                <field name="call_date" interval="day" type="row"/>
                <field name="provider" type="col"/>
                <field name="id" type="measure" string="# Calls"/>
            </graph>
        </field>
    </record>

    <!-- ── Pivot view — cost / token analysis ────────────────────────────── -->
    <record id="view_doc_intel_quota_log_pivot" model="ir.ui.view">
        <field name="name">document.intelligence.quota.log.pivot</field>
        <field name="model">document.intelligence.quota.log</field>
        <field name="arch" type="xml">
            <pivot string="Extraction Analytics" display_quantity="true">
                <field name="call_date" interval="month" type="row"/>
                <field name="provider" type="col"/>
                <field name="estimated_tokens" type="measure" string="Tokens"/>
                <field name="response_ms" type="measure" string="Avg Time (ms)"/>
                <field name="id" type="measure" string="# Calls"/>
            </pivot>
        </field>
    </record>

    <!-- ── Search view ────────────────────────────────────────────────────── -->
    <record id="view_doc_intel_quota_log_search" model="ir.ui.view">
        <field name="name">document.intelligence.quota.log.search</field>
        <field name="model">document.intelligence.quota.log</field>
        <field name="arch" type="xml">
            <search string="Search Quota Log">
                <field name="provider"/>
                <field name="model_used"/>
                <field name="user_id"/>
                <separator/>
                <filter name="filter_success" string="Successful" domain="[('success','=',True)]"/>
                <filter name="filter_failed" string="Failed" domain="[('success','=',False)]"/>
                <separator/>
                <filter name="filter_openai" string="OpenAI" domain="[('provider','=','openai')]"/>
                <filter name="filter_groq" string="Groq" domain="[('provider','=','groq')]"/>
                <filter name="filter_anthropic" string="Anthropic" domain="[('provider','=','anthropic')]"/>
                <filter name="filter_ollama" string="Ollama (Local)" domain="[('provider','=','ollama')]"/>
                <separator/>
                <filter name="filter_today" string="Today"
                        domain="[('call_date','&gt;=', datetime.datetime.combine(context_today(), datetime.time(0,0,0)).strftime('%Y-%m-%d %H:%M:%S'))]"/>
                <filter name="filter_this_month" string="This Month"
                        domain="[('call_date','&gt;=', (context_today() - relativedelta(months=1)).strftime('%Y-%m-01 00:00:00'))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_provider" string="Provider"
                            context="{'group_by': 'provider'}"/>
                    <filter name="group_user" string="User"
                            context="{'group_by': 'user_id'}"/>
                    <filter name="group_date" string="Date"
                            context="{'group_by': 'call_date:day'}"/>
                    <filter name="group_month" string="Month"
                            context="{'group_by': 'call_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Action — opens tree + graph + pivot ────────────────────────────── -->
    <record id="action_doc_intel_quota_log" model="ir.actions.act_window">
        <field name="name">Extraction Analytics</field>
        <field name="res_model">document.intelligence.quota.log</field>
        <field name="view_mode">graph,pivot,tree</field>
        <field name="context">{'search_default_filter_success': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No API calls logged yet.</p>
            <p>API calls appear here after the first document is extracted using
               Ollama or a Cloud AI provider (Groq, OpenAI, Anthropic).</p>
        </field>
    </record>

</odoo>
