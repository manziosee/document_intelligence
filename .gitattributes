# Force LF line endings for all files in this repo.
# Prevents Windows git from converting LF → CRLF, which can cause
# Odoo's XML parser to miscount line numbers and raise spurious errors.

* text=auto eol=lf

# Explicitly enforce LF on key file types
*.py   text eol=lf
*.xml  text eol=lf
*.csv  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.rst  text eol=lf
*.txt  text eol=lf
*.scss text eol=lf
*.js   text eol=lf

# Binary — never touch line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
