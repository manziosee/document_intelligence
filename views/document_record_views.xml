<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── List / Tree view ───────────────────────────────────────────────── -->
    <record id="view_document_intelligence_record_list" model="ir.ui.view">
        <field name="name">document.intelligence.record.list</field>
        <field name="model">document.intelligence.record</field>
        <field name="arch" type="xml">
            <tree string="Documents"
                  decoration-success="state == 'done'"
                  decoration-danger="state == 'error'"
                  decoration-warning="state == 'review'"
                  decoration-muted="state == 'draft'">
                <field name="name"/>
                <field name="input_mode" optional="show"/>
                <field name="file_name"/>
                <field name="source_record_display" optional="show" string="Linked Record"/>
                <field name="detected_document_type"/>
                <field name="extraction_mode"/>
                <field name="ocr_language" optional="hide"/>
                <field name="confidence_score" widget="progressbar"
                       options="{'editable': false}"/>
                <field name="vendor_name"/>
                <field name="document_date"/>
                <field name="total_amount"/>
                <field name="currency_detected"/>
                <field name="suggested_action"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'error'"
                       decoration-warning="state == 'review'"
                       decoration-info="state == 'processing'"/>
                <field name="create_date" string="Created"/>
            </tree>
        </field>
    </record>

    <!-- ── Form view ──────────────────────────────────────────────────────── -->
    <record id="view_document_intelligence_record_form" model="ir.ui.view">
        <field name="name">document.intelligence.record.form</field>
        <field name="model">document.intelligence.record</field>
        <field name="arch" type="xml">
            <form string="Document Intelligence">
                <header>
                    <button name="action_extract"
                            string="Extract Data"
                            type="object"
                            class="btn-primary"
                            invisible="state not in ('draft',)"
                            data-hotkey="e"/>
                    <button name="action_open_review"
                            string="Review &amp; Create Record"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'review'"/>
                     <button name="action_create_odoo_record"
                             string="Create Odoo Record"
                             type="object"
                             class="btn-secondary"
                             invisible="state != 'review'"
                             confirm="Create the Odoo record now without reviewing again?"/>
                     <button name="action_create_expense_claim"
                             string="Create Expense"
                             type="object"
                             class="btn-secondary"
                             invisible="state != 'review' or not is_receipt"/>
                     <button name="action_match_bank_statement"
                             string="Match Bank"
                             type="object"
                             class="btn-secondary"
                             invisible="state != 'review' or not detected_document_type in ('invoice','receipt') or not bank_statement_line_id"
                             help="Match this document to a bank statement line for reconciliation"/>
                     <button name="action_reset_to_draft"
                             string="Reset to Draft"
                             type="object"
                             invisible="state in ('draft', 'done')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,processing,review,done"/>
                </header>

                <sheet>
                    <!-- Stat buttons -->
                    <div name="button_box" class="oe_button_box">
                        <button class="oe_stat_button" type="object"
                                name="action_view_quota_logs"
                                icon="fa-bar-chart"
                                invisible="quota_log_count == 0">
                            <field name="quota_log_count" widget="statinfo"
                                   string="API Calls"/>
                        </button>
                        <button class="oe_stat_button" type="object"
                                name="action_view_error_logs"
                                icon="fa-exclamation-triangle"
                                invisible="error_log_count == 0">
                            <field name="error_log_count" widget="statinfo"
                                   string="Errors"/>
                        </button>
                    </div>

                    <!-- Hidden fields used in invisible modifiers -->
                    <field name="is_receipt" invisible="1"/>

                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Document name..."/>
                        </h1>
                    </div>

                    <!-- Source linked record info -->
                    <div class="alert alert-secondary"
                         invisible="not source_record_display" role="note">
                        <i class="fa fa-link"/> Linked from:
                        <strong>
                            <field name="source_record_display" readonly="1" nolabel="1"/>
                        </strong>
                    </div>

                    <!-- Input mode toggle -->
                    <group string="Document Source" invisible="state != 'draft'">
                        <field name="input_mode" widget="radio" nolabel="1"
                               options="{'horizontal': true}"/>
                    </group>

                    <!-- Option A: upload new file -->
                    <group string="Upload New File"
                           invisible="input_mode != 'upload' or state != 'draft'">
                        <group>
                            <field name="file_data" filename="file_name"
                                   widget="binary" string="Choose File"/>
                            <field name="file_name" readonly="1"/>
                            <field name="file_mimetype" readonly="1"/>
                        </group>
                    </group>

                    <!-- Option B: pick existing Odoo attachment -->
                    <group string="Select Existing Odoo Document"
                           invisible="input_mode != 'existing' or state != 'draft'">
                        <group>
                            <field name="source_attachment_id"
                                   domain="[('type', '=', 'binary')]"
                                   options="{'no_create': True}"/>
                            <field name="file_name" readonly="1"/>
                        </group>
                        <group>
                            <field name="source_record_display" readonly="1"
                                   invisible="not source_record_display"/>
                        </group>
                    </group>

                    <!-- Extraction config -->
                    <group string="Extraction Settings" invisible="state != 'draft'">
                        <group>
                            <field name="extraction_mode" widget="radio"/>
                            <field name="ocr_language"
                                   placeholder="eng"
                                   help="Tesseract language code(s). Example: eng, fra, eng+fra+kin"/>
                            <field name="force_re_ocr"
                                   invisible="not raw_text"
                                   help="Force new OCR even if raw text was already extracted"/>
                        </group>
                        <group>
                            <field name="template_id"
                                   invisible="extraction_mode != 'template'"
                                   required="extraction_mode == 'template'"/>
                            <field name="custom_fields_input"
                                   invisible="extraction_mode != 'custom'"
                                   required="extraction_mode == 'custom'"
                                   placeholder="vendor, date, total, phone, address"/>
                            <field name="extra_prompt"
                                   placeholder="Extra AI context (optional)..."/>
                        </group>
                    </group>

                    <!-- AI Results -->
                    <group string="Extraction Results"
                           invisible="state in ('draft', 'processing')">
                        <group>
                            <field name="detected_document_type"/>
                            <field name="suggested_action"/>
                            <field name="confidence_score" widget="progressbar"
                                   options="{'editable': false}"/>
                        </group>
                        <group>
                            <field name="partner_id"/>
                            <field name="linked_move_id" readonly="1"
                                   invisible="not linked_move_id"/>
                            <field name="linked_applicant_id" readonly="1"
                                   invisible="not linked_applicant_id"/>
                            <field name="processing_notes" readonly="1"
                                   invisible="not processing_notes"/>
                        </group>
                    </group>

                    <!-- Extracted + editable data -->
                    <notebook invisible="state in ('draft', 'processing')">
                         <page string="Business Data" name="business_data">
                             <group col="2">
                                 <group string="Document Details">
                                     <field name="vendor_name"/>
                                     <field name="reference_number"/>
                                     <field name="document_date"/>
                                     <field name="total_amount"/>
                                     <field name="currency_detected"/>
                                     <field name="tax_amount"/>
                                     <field name="vat_number"/>
                                     <field name="iban"/>
                                     <field name="swift"/>
                                 </group>
                                 <group string="Contact Info">
                                     <field name="contact_name"/>
                                     <field name="contact_phone"/>
                                     <field name="contact_email"/>
                                     <field name="contact_address" widget="text"/>
                                 </group>
                                 <group string="Bank Reconciliation" invisible="detected_document_type not in ('invoice','receipt')">
                                     <field name="bank_statement_line_id" readonly="1"/>
                                     <field name="reconciliation_status" readonly="1"/>
                                     <button name="action_match_bank_statement" string="Match Bank Statement" type="object"
                                             class="btn-secondary" invisible="state != 'review' or bank_statement_line_id"/>
                                 </group>
                                 <group string="Expense Claim" invisible="not is_receipt">
                                     <field name="expense_employee_id"/>
                                 </group>
                             </group>
                             <group string="Other Extracted Fields"
                                    invisible="not extra_fields_display">
                                 <field name="extra_fields_display"
                                        readonly="1" nolabel="1" colspan="2"/>
                             </group>
                         </page>

                        <page string="Raw OCR Text" name="raw_text">
                            <div class="alert alert-info" role="note">
                                <i class="fa fa-info-circle"/>
                                Raw text from OCR. The AI used this to extract structured data.
                                Enable <strong>Force Re-OCR</strong> on Draft to regenerate it.
                            </div>
                            <field name="raw_text" readonly="1" nolabel="1"
                                   widget="text"
                                   style="font-family: monospace; font-size: 12px; white-space: pre-wrap;"/>
                        </page>

                        <page string="Extracted JSON" name="extracted_json">
                            <field name="extracted_data_json" readonly="1" nolabel="1"
                                   widget="text"
                                   style="font-family: monospace; font-size: 12px;"/>
                        </page>

                        <page string="Line Items" name="line_items"
                              invisible="not line_item_ids">
                            <field name="line_item_ids" nolabel="1">
                                <tree string="Extracted Line Items" editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="description"/>
                                    <field name="quantity"/>
                                    <field name="unit_price"/>
                                    <field name="price_subtotal" readonly="1"/>
                                    <field name="product_id" optional="show"/>
                                    <field name="needs_review" widget="boolean_toggle"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Created Records" name="created_records"
                              invisible="not created_move_id and not created_partner_id">
                            <group>
                                <field name="created_move_id" readonly="1"/>
                                <field name="created_partner_id" readonly="1"/>
                            </group>
                        </page>
                    </notebook>

                    <!-- Processing spinner -->
                    <div class="alert alert-info" role="status"
                         invisible="state != 'processing'">
                        <i class="fa fa-spinner fa-spin"/>
                        Processing document — OCR and AI extraction in progress...
                    </div>

                    <!-- Error banner -->
                    <div class="alert alert-danger" role="alert"
                         invisible="state != 'error'">
                        <strong>Extraction failed.</strong>
                        <span>
                            <field name="processing_notes" readonly="1" nolabel="1"/>
                        </span>
                    </div>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── Kanban view ─────────────────────────────────────────────────────── -->
    <record id="view_document_intelligence_record_kanban" model="ir.ui.view">
        <field name="name">document.intelligence.record.kanban</field>
        <field name="model">document.intelligence.record</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="state"/>
                <field name="detected_document_type"/>
                <field name="vendor_name"/>
                <field name="total_amount"/>
                <field name="confidence_score"/>
                <field name="file_name"/>
                <field name="input_mode"/>
                <field name="source_record_display"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_title">
                                    <strong><field name="name"/></strong>
                                </div>
                                <div class="o_kanban_record_subtitle">
                                    <span class="text-muted">
                                        <field name="detected_document_type"/>
                                    </span>
                                </div>
                                <div t-if="record.vendor_name.raw_value">
                                    <i class="fa fa-building-o"/>
                                    <field name="vendor_name"/>
                                </div>
                                <div t-if="record.total_amount.raw_value">
                                    <i class="fa fa-money"/>
                                    <field name="total_amount"/>
                                    <field name="currency_detected"/>
                                </div>
                                <div class="o_kanban_record_bottom mt-2">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="confidence_score" widget="progressbar"
                                               options="{'editable': false}"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ── Search view ─────────────────────────────────────────────────────── -->
    <record id="view_document_intelligence_record_search" model="ir.ui.view">
        <field name="name">document.intelligence.record.search</field>
        <field name="model">document.intelligence.record</field>
        <field name="arch" type="xml">
            <search string="Search Documents">
                <field name="name"/>
                <field name="vendor_name"/>
                <field name="reference_number"/>
                <field name="contact_email"/>
                <field name="source_record_display" string="Source Record"/>
                <separator/>
                <filter name="filter_uploaded" string="Uploaded Files"
                        domain="[('input_mode','=','upload')]"/>
                <filter name="filter_from_odoo" string="From Odoo Records"
                        domain="[('input_mode','=','existing')]"/>
                <separator/>
                <filter name="filter_draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="filter_review" string="Pending Review" domain="[('state','=','review')]"/>
                <filter name="filter_done" string="Done" domain="[('state','=','done')]"/>
                <filter name="filter_error" string="Errors" domain="[('state','=','error')]"/>
                <separator/>
                <filter name="filter_invoice" string="Invoices"
                        domain="[('detected_document_type','in',['invoice','proforma'])]"/>
                <filter name="filter_receipt" string="Receipts"
                        domain="[('detected_document_type','=','receipt')]"/>
                <filter name="filter_cv" string="CVs"
                        domain="[('detected_document_type','=','cv')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="Status"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_doc_type" string="Document Type"
                            context="{'group_by': 'detected_document_type'}"/>
                    <filter name="group_mode" string="Input Mode"
                            context="{'group_by': 'input_mode'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>