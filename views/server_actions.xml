<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════════════
         account.move — "Extract with AI" in Actions menu + smart button
    ═══════════════════════════════════════════════════════════════════════ -->

    <!-- Smart button on invoice/bill form -->
    <record id="view_account_move_doc_intel_button" model="ir.ui.view">
        <field name="name">account.move.doc.intel.button</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button"
                        type="object"
                        name="action_open_doc_intel"
                        icon="fa-file-text-o"
                        invisible="doc_intel_count == 0">
                    <field name="doc_intel_count" widget="statinfo"
                           string="AI Extracted"/>
                </button>
                <button class="oe_stat_button"
                        type="object"
                        name="action_extract_with_ai"
                        icon="fa-magic"
                        title="Extract data from attached documents using OCR + AI">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Extract</span>
                        <span class="o_stat_text">with AI</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

    <!-- Server action: Actions menu on invoice list/form -->
    <record id="server_action_account_move_extract" model="ir.actions.server">
        <field name="name">Extract with Document Intelligence</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">
if records:
    action = records[0].action_extract_with_ai()
</field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         hr.applicant — "Extract CV with AI" + smart button
    ═══════════════════════════════════════════════════════════════════════ -->

    <!-- HR applicant smart button + server action: only loaded when hr_recruitment is installed -->
    <!-- These are registered via hr_applicant_ext.py at runtime; no XML view needed here -->

    <!-- ══════════════════════════════════════════════════════════════════════
         Access rights for the new wizard
    ═══════════════════════════════════════════════════════════════════════ -->

</odoo>
