<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Groups -->
    <record id="group_document_intelligence_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="base.module_category_productivity"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_document_intelligence_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="base.module_category_productivity"/>
        <field name="implied_ids" eval="[(4, ref('group_document_intelligence_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <!-- Batch Processing Access -->
    <record id="group_document_intelligence_batch_user" model="res.groups">
        <field name="name">Batch Processing User</field>
        <field name="category_id" ref="base.module_category_productivity"/>
        <field name="implied_ids" eval="[(4, ref('group_document_intelligence_user'))]"/>
    </record>

    <record id="group_document_intelligence_batch_manager" model="res.groups">
        <field name="name">Batch Processing Manager</field>
        <field name="category_id" ref="base.module_category_productivity"/>
        <field name="implied_ids" eval="[(4, ref('group_document_intelligence_batch_user'))]"/>
    </record>

    <!-- Email Processing Access -->
    <record id="group_document_intelligence_email_user" model="res.groups">
        <field name="name">Email Integration User</field>
        <field name="category_id" ref="base.module_category_productivity"/>
        <field name="implied_ids" eval="[(4, ref('group_document_intelligence_user'))]"/>
    </record>

    <!-- Custom Rules Access -->
    <record id="group_document_intelligence_rules_user" model="res.groups">
        <field name="name">Custom Rules User</field>
        <field name="category_id" ref="base.module_category_productivity"/>
        <field name="implied_ids" eval="[(4, ref('group_document_intelligence_user'))]"/>
    </record>

    <!-- Audit & Reporting Access -->
    <record id="group_document_intelligence_audit_user" model="res.groups">
        <field name="name">Audit &amp; Reporting User</field>
        <field name="category_id" ref="base.module_category_productivity"/>
        <field name="implied_ids" eval="[(4, ref('group_document_intelligence_user'))]"/>
    </record>

</odoo>
